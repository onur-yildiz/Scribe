<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>Solw.Scribe</PackageId>
    <Version>1.0.0</Version>
    <Authors>Onur YILDIZ</Authors>
    <Description>Lightweight diagnostics library for tracing operations and persisting activity records to MongoDB.</Description>
    <PackageTags>diagnostics;logging;tracing;mongodb;dotnet</PackageTags>
    <PackageProjectUrl>https://github.com/onur-yildiz/Scribe</PackageProjectUrl>
    <RepositoryUrl>https://github.com/onur-yildiz/Scribe</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.3" />
    <PackageReference Include="MongoDB.Driver" Version="3.6.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" Link="README.md" />
  </ItemGroup>

</Project>
